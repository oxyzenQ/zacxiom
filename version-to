#!/usr/bin/env bash
# version-to — Single source of truth for version bumping.
# Usage: ./version-to v1.0.1
set -euo pipefail

if [ $# -ne 1 ]; then
  echo "Usage: $0 <version>"
  echo "Example: $0 v1.0.1"
  exit 1
fi

VERSION="${1#v}"  # strip leading v if present
CUR="$(grep '^version = ' Cargo.toml | head -1 | sed 's/version = "\(.*\)"/\1/')"

echo "Bumping version: v${CUR} → v${VERSION}"

# Cargo.toml
sed -i "s/^version = \"${CUR}\"/version = \"${VERSION}\"/" Cargo.toml

echo "Version bumped to v${VERSION}"
echo "Run: ./build.sh check-all && git add -A && git commit -m 'chore: bump to v${VERSION}'"
